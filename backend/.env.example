# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── Environment ────────────────────────────────────────────────────────────────
# Set to "production" on Render to disable static file serving
APP_ENV=development
PUBLIC_BASE_URL=http://localhost:8000

# ── Secrets ────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-jwt-secret-key-here
QR_HMAC_SECRET=your-qr-hmac-secret-here
DEACTIVATION_HMAC_SECRET=your-deactivation-hmac-secret-here

# ── Database ───────────────────────────────────────────────────────────────────
# LOCAL  : sqlite:///./evsu_clinic.db
# NEON   : postgresql://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=sqlite:///./evsu_clinic.db

# ── OTP ────────────────────────────────────────────────────────────────────────
OTP_EXPIRE_MINUTES=15
OTP_MAX_ATTEMPTS=3

# ── Email (Brevo SMTP via Port 2525) ──────────────────────────────────────────────────────────
BREVO_SMTP_LOGIN=your_brevo_login_email
BREVO_SMTP_PASSWORD=your_brevo_smtp_master_password
EMAIL_FROM=taskerrandemail@gmail.com

# ── CORS ───────────────────────────────────────────────────────────────────────
# LOCAL  : ["http://localhost:5500","http://localhost:8000","http://127.0.0.1:8000"]
# PROD   : ["https://your-app.netlify.app"]
ALLOWED_ORIGINS=["http://localhost:5500","http://localhost:8000","http://127.0.0.1:8000"]

# ── Seed passwords ─────────────────────────────────────────────────────────────
SEED_ADMIN_PASSWORD=
SEED_RESPONDER_PASSWORD=
